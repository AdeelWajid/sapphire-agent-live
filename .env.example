GEMINI_API_KEY=your_gemini_api_key_here

# Text / generateContent helpers
GEMINI_TEXT_MODEL=gemini-3.1-flash-lite

# Live voice WebSocket — MUST be a Live-capable model
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview

# Live transcripts add text-output cost; keep false for cheapest runs
GEMINI_LIVE_TRANSCRIPTS=false

PORT=3000
