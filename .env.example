GEMINI_API_KEY=your_gemini_api_key_here

# Text / generateContent helpers
GEMINI_TEXT_MODEL=gemini-3.1-flash-lite

# Live voice WebSocket — MUST be a Live-capable model
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview

# Live transcripts (needed to log/view call chat). Set false to reduce cost.
GEMINI_LIVE_TRANSCRIPTS=true

PORT=3000

# Optional: directory for communication logs (default: ./logs)
# LOG_DIR=./logs
