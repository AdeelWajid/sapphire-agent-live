<?xml version="1.0" encoding="utf-8"?>
<!-- Alert circle icon (Lucide-style) -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Circle outline -->
    <path
        android:strokeColor="#E32934"
        android:strokeWidth="1.8"
        android:fillColor="@android:color/transparent"
        android:pathData="M12,2 A10,10 0 1 1 12,22 A10,10 0 1 1 12,2 Z" />

    <!-- Exclamation stem -->
    <path
        android:strokeColor="#E32934"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:fillColor="@android:color/transparent"
        android:pathData="M12,8 L12,12" />

    <!-- Exclamation dot -->
    <path
        android:fillColor="#E32934"
        android:pathData="M12,16 A0.5,0.5 0 1 1 12,17 A0.5,0.5 0 1 1 12,16 Z" />
</vector>
