<?xml version="1.0" encoding="utf-8"?>
<!--
  Home screen matching design reference:
  header → greeting → compact blue card → 3 action cards → Start Conversation
  No layout_weight on the blue card (that made it fill the screen).
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:fillViewport="true"
    android:layout_height="match_parent">
<LinearLayout
    android:id="@+id/homeRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/bg_screen"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:background="@color/white"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <ImageView
            android:id="@+id/ivPepsiLogo"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:contentDescription="@string/pepsi_logo_desc"
            android:src="@drawable/ic_pepsi_logo" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvAppTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_title"
                android:textColor="@color/pepsi_blue_deep"
                android:textSize="22sp"
                android:textStyle="bold" />


        </LinearLayout>

        <TextView
            android:id="@+id/btnLogout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            android:text="@string/logout"
            android:textColor="@color/pepsi_blue_bright"
            android:textSize="13sp"
            android:textStyle="bold" />

    </LinearLayout>



      <LinearLayout
          android:layout_marginHorizontal="40dp"
          android:orientation="vertical"
          android:layout_width="match_parent"
          android:layout_height="wrap_content">
          <!-- Welcome heading -->
          <TextView
              android:id="@+id/tvGreeting"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_gravity="center"
              android:layout_marginTop="18dp"
              android:text="@string/greeting"
              android:textAlignment="center"
              android:textColor="@color/text_dark"
              android:textSize="26sp"
              android:textStyle="bold" />

          <!-- Agent introduction -->
          <TextView

              android:id="@+id/tvAgentIntroduction"
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:layout_marginTop="6dp"
              android:layout_marginBottom="18dp"
              android:gravity="center"
              android:lineSpacingExtra="3dp"
              android:maxLines="3"
              android:justificationMode="inter_word"
              android:text="@string/agent_introduction"
              android:textAlignment="center"
              android:textColor="@color/text_muted"
              android:textSize="14sp" />

      </LinearLayout>


    <!-- Compact blue agent card (NOT full screen) -->
    <androidx.cardview.widget.CardView
        android:layout_marginTop="20dp"
        android:id="@+id/cardHeroAgent"
        android:layout_width="match_parent"
        android:layout_marginHorizontal="40dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp"
        app:cardPreventCornerOverlap="false">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_hero_card">

            <View
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="-28dp"
                android:layout_marginEnd="-28dp"
                android:alpha="0.07"
                android:background="@drawable/shape_deco_circle_white_sm" />

            <View
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:layout_gravity="bottom|start"
                android:layout_marginStart="-20dp"
                android:layout_marginBottom="-20dp"
                android:alpha="0.05"
                android:background="@drawable/shape_deco_circle_white_sm" />

            <LinearLayout

                 android:layout_marginTop="40dp"
                android:layout_marginBottom="40dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <!-- Pulse rings kept for animation, but compact -->
                <FrameLayout
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:layout_marginBottom="12dp">

                    <View
                        android:id="@+id/vOuterRing"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/shape_avatar_ring_outer" />

                    <View
                        android:id="@+id/vInnerRing"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:layout_gravity="center"
                        android:background="@drawable/shape_avatar_ring_inner" />

                    <FrameLayout
                        android:id="@+id/flAvatarMain"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_avatar_circle">

                        <ImageView
                            android:id="@+id/ivAgentIcon"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_gravity="center"
                            android:contentDescription="@string/agent_icon_desc"
                            android:src="@drawable/ic_globe"
                            app:tint="@color/white" />
                    </FrameLayout>
                </FrameLayout>

                <TextView
                    android:id="@+id/tvAgentName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_title"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvAgentStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="@string/agent_status"
                    android:textColor="#D9FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvAgentDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.3"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:text="@string/agent_description"
                    android:textColor="#B8FFFFFF"
                    android:textSize="12sp" />
            </LinearLayout>
        </FrameLayout>
    </androidx.cardview.widget.CardView>

    <!-- 3 action items BELOW the blue card -->
    <LinearLayout
        android:layout_marginTop="10dp"
        android:id="@+id/sectionQuickActions"
        android:layout_width="match_parent"

        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:orientation="horizontal"
        android:paddingStart="40dp"
        android:paddingEnd="40dp">

        <LinearLayout
            android:id="@+id/cardPlaceOrder"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_action_card"
            android:clickable="true"

            android:focusable="true"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingTop="14dp"
            android:paddingBottom="14dp">

            <FrameLayout
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_icon_circle">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:contentDescription="@string/place_order_icon_desc"
                    android:src="@drawable/ic_package"
                    app:tint="@color/pepsi_blue_deep" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/action_place_order"
                android:textColor="@color/text_dark"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:gravity="center"
                android:text="@string/action_place_order_sub"
                android:textColor="@color/text_muted"
                android:textSize="9sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardReportIssue"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:background="@drawable/bg_action_card"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingTop="14dp"
            android:paddingBottom="14dp">

            <FrameLayout
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_icon_circle">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:contentDescription="@string/report_issue_icon_desc"
                    android:src="@drawable/ic_alert_circle"
                    app:tint="@color/pepsi_red" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/action_report_issue"
                android:textColor="@color/text_dark"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:gravity="center"
                android:text="@string/action_report_issue_sub"
                android:textColor="@color/text_muted"
                android:textSize="9sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardCatalogue"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_action_card"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingTop="14dp"
            android:paddingBottom="14dp">

            <FrameLayout
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_icon_circle">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:contentDescription="@string/catalogue_icon_desc"
                    android:src="@drawable/ic_book_open"
                    app:tint="@color/pepsi_blue_bright" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/action_catalogue"
                android:textColor="@color/text_dark"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:gravity="center"
                android:text="@string/action_catalogue_sub"
                android:textColor="@color/text_muted"
                android:textSize="9sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Start Conversation BELOW the 3 items -->
    <LinearLayout
        android:layout_marginTop="10dp"
        android:layout_marginHorizontal="40dp"
        android:id="@+id/sectionCta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:id="@+id/btnStartConversation"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_start_button"
            android:clickable="true"
            android:elevation="6dp"
            android:focusable="true"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="@string/btn_start_conversation"
                android:src="@drawable/ic_phone_cta" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="@string/btn_start_conversation"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvLanguageNote"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="8dp"
            android:text="@string/language_note"
            android:textColor="@color/text_muted"
            android:textSize="12sp" />

    </LinearLayout>

</LinearLayout>
</ScrollView>
