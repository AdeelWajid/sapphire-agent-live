<?xml version="1.0" encoding="utf-8"?>
<!--
    Ripple-out animation for the Start Conversation button press.
    Usage:
        binding.btnStartConversation.setOnClickListener {
            val anim = AnimationUtils.loadAnimation(this, R.anim.btn_ripple_out)
            binding.btnStartConversation.startAnimation(anim)
        }
-->
<set xmlns:android="http://schemas.android.com/apk/res/android">
    <scale
        android:duration="120"
        android:fromXScale="1.0"
        android:fromYScale="1.0"
        android:toXScale="0.96"
        android:toYScale="0.96"
        android:pivotX="50%"
        android:pivotY="50%"
        android:interpolator="@android:anim/decelerate_interpolator" />

    <scale
        android:duration="200"
        android:startOffset="120"
        android:fromXScale="0.96"
        android:fromYScale="0.96"
        android:toXScale="1.02"
        android:toYScale="1.02"
        android:pivotX="50%"
        android:pivotY="50%"
        android:interpolator="@android:anim/overshoot_interpolator" />

    <scale
        android:duration="120"
        android:startOffset="320"
        android:fromXScale="1.02"
        android:fromYScale="1.02"
        android:toXScale="1.0"
        android:toYScale="1.0"
        android:pivotX="50%"
        android:pivotY="50%" />
</set>
